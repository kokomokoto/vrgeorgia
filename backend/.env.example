# ======================================
# VR Georgia Backend — Environment Variables
# ======================================
# ლოკალურად: cp .env.example .env
# პროდაქშენზე: Render.com → Environment tab

# Server
NODE_ENV=development
PORT=5000

# MongoDB
# ლოკალური:
MONGODB_URI=mongodb://127.0.0.1:27017/vrgeorgia
# პროდაქშენი (MongoDB Atlas):
# MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/vrgeorgia?retryWrites=true&w=majority

# JWT (პროდაქშენზე აუცილებლად შეცვალე!)
JWT_SECRET=change_me_to_a_long_random_string_min_64_chars
JWT_EXPIRES_IN=7d

# CORS — ნებადართული ფრონტენდ დომენები
# ლოკალურად არ არის საჭირო (dev-ზე ყველა დაშვებულია)
# ALLOWED_ORIGINS=https://vrgeorgia.ge,https://www.vrgeorgia.ge

# Optional: Google Cloud Translate
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=
